PORT=8000
MONGO_URI=mongodb://127.0.0.1:27017/abu-portfolio

JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Required on the admin signup page. Never expose this value in frontend code.
ADMIN_SIGNUP_KEY=replace-with-a-private-admin-setup-key

SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password

CORS_ORIGINS=http://localhost:5173,https://xab.net.az

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
